{
  "manifest_version": 3,
  "name": "Job Fill",
  "version": "0.1.0",
  "description": "Auto-fills job applications on Workday, Greenhouse, Lever, Ashby, and more.",
  "browser_specific_settings": {
    "gecko": {
      "id": "job-fill@example.com",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Fill",
    "default_icon": {
      "48": "assets/icon-48.png",
      "96": "assets/icon-96.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline';"
  },
  "icons": {
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png"
  }
}
