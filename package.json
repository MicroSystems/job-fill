{
  "name": "job-fill",
  "version": "0.1.0",
  "private": true,
  "description": "Firefox extension that auto-fills job applications across Workday, Greenhouse, Lever, Ashby, and more.",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "package": "webpack --mode production && cd dist && web-ext build --overwrite-dest",
    "lint": "tsc --noEmit",
    "start:firefox": "webpack --mode development && web-ext run --source-dir dist --firefox=firefoxdeveloperedition"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.0.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "web-ext": "^8.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
